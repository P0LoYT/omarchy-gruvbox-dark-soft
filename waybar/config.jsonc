      "class<microsoft-edge>": "´èé",
      "class<Chromium|Thorium|[Cc]hrome>": "´ë¿",
      "class<brave-browser>": "­ƒªü",
      "class<tor-browser>": "´ì▒",
      "class<firefox-developer-edition>": "­ƒªè",
      "class<kitty|konsole>": "¯»å",
      "class<kitty-dropterm>": "´äá",
      "class<foot>": "¾░¢Æ",
      "class<com.mitchellh.ghostty>": "¯×ò",
      "class<org.wezfurlong.wezterm>": "¯¬à",
      "class<org.omarchy.terminal>": "¾░Åû",
      "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "´ì░",
      "class<eu.betterbird.Betterbird>": "´ì░",
      "title<.*gmail.*>": "¾░è½",
      "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "¯êù",
      "class<discord|[Ww]ebcord|Vesktop>": "´ç┐",
      "title<.*whatsapp.*>": "´ê▓",
      "title<.*zapzap.*>": "´ê▓",
      "title<.*messenger.*>": "´ëƒ",
      "title<.*facebook.*>": "´éÜ ",
      "title<.*reddit.*>": "´èü",
      "title<.*ChatGPT.*>": "¾░Ü®",
      "class<.*ChatGPT.*>": "¾░Ü®",
      "title<.*deepseek.*>": "¾░Ü®",
      "title<.*qwen.*>": "¾░Ü®",
      "class<subl>": "¾░à│",
      "class<slack>": "´åÿ",
      "class<mpv>": "´ì«",
      "class<celluloid|Zoom>": "´Ç¢",
      "class<Cider>": "¾░Äå ",
      "title<.*Picture-in-Picture.*>": "´ö¼",
      "title<.*youtube.*>": "´à¬",
      "class<vlc>": "¾░ò╝",
      "title<.*cmus.*>": "´Çü",
      "class<[Ss]potify>": "´å╝",
      "class<virt-macodeger>": "¯¡╗",
      "class<.virt-manager-wrapped>": "¯¡╗",
      "class<virtualbox manager>": "­ƒÆ¢",
      "title<virtualbox>": "­ƒÆ¢",
      "class<remmina>": "­ƒûÑ´©Å",
      "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "¾░¿×",
      "class<dev.zed.Zed>": "¾░Áü",
      "class<codeblocks>": "¾░à®",
      "title<.*github.*>": "´äô",
      "class<mousepad>": "´à£",
      "class<libreoffice-writer>": "¯ÜÑ",
      "class<libreoffice-startcenter>": " ¾░Åå",
      "class<libreoffice-calc>": "´ì╗",
      "title<.*nvim ~.*>": "´ì»",
      "class<org.gnome.Nautilus>": "¾░úå",
      "title<.*vim.*>": "¯ƒà",
      "title<.*figma.*>": "¯¢ç",
      "title<.*jira.*>": "¯Ø£",
      "class<jetbrains-idea>": "¯×Á",
      "title<*.VSCode.*>": "¾░¿×",
      "class<.*code.*>": "¾░¿×",
      "class<obs|com.obsproject.Studio>": "¯«º",
      "class<polkit-gnome-authentication-agent-1>": "¾░Æâ",
      "class<nwg-look>": "¯¡Æ",
      "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "¾▒í½",
      "class<steam>": "´åÂ",
      "class<thunar|nemo>": "¾░Ø░",
      "class<Gparted>": "´âç",
      "class<gimp>": "´î©",
      "class<emulator>": "­ƒô▒",
      "class<android-studio>": "´à╗",
      "class<org.pipewire.Helvum>": "¾░ôâ",
      "class<localsend>": "´çá",
      "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø"
    }
  },
  "custom/update": {
    "format": "´Çí",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 21600
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "¾░øè",
      "deactivated": "¾░¥¬"
    }
  },
  "cpu": {
    "interval": 2,
    "format": "¾░ìø {usage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
  "memory": {
    "interval": 2,
    "format": "¯ëª {percentage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
  "clock": {
    "format": "{:%H:%M }",
    "format-alt": "{:%H:%M %d/%m/%Y}",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      }
    }
  },
  "network": {
    "format-icons": [
      "¾░ñ»",
      "¾░ñƒ",
      "¾░ñó",
      "¾░ñÑ",
      "¾░ñ¿"
    ],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░êÇ",
    "format-disconnected": "¾░ñ«",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)",
    "tooltip-format-ethernet": "Connected",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "´çª",
    "format-icons": {
      "charging": [
        "¾░ó£",
        "¾░éå",
        "¾░éç",
        "¾░éê",
        "¾░óØ",
        "¾░éë",
        "¾░ó×",
        "¾░éè",
        "¾░éï",
        "¾░éà"
      ],
      "default": [
        "¾░ü║",
        "¾░ü╗",
        "¾░ü╝",
        "¾░ü¢",
        "¾░ü¥",
        "¾░ü┐",
        "¾░éÇ",
        "¾░éü",
        "¾░éé",
        "¾░ü╣"
      ]
    },
    "format-full": "¾░éà {capacity}%",
    "tooltip-format-discharging": "{timeTo}",
    "tooltip-format-charging": "{timeTo}",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "on-click-right": "notify-send -u low \"$(omarchy-battery-status)\"",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "´èö",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },
  "pulseaudio#input": {
    "format-source": "´ä░",
    "format-source-muted": "´ä▒ ",
    "format": "{format_source}",
    "tooltip-format": "{format_source} {source_volume}%",
    "scroll-step": 1,
    "smooth-scrolling-threshold": 1,
    "max-volume": 100,
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +1%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -1%"
  },
  "pulseaudio#output": {
    "format": "{icon}",
    "tooltip-format": "{icon}  {volume}%",
    "format-muted": "´Çª off",
    "format-icons": {
      "default": [
        "´ÇÑ"
      ]
    },
    "max-volume": 100,
    "scroll-step": 2,
    "smooth-scrolling-threshold": 1,
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾░ôà",
      "performance": "¾░ôà",
      "balanced": "¾░¥à",
      "power-saver": "¾░¥å"
    }
  },
  "custom/updatespacman": {
    "format": "{}{icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": " ¾░Åû",
      "updated": ""
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --no-zero-output"
  }
}