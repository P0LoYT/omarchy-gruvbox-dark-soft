{
  "exclusive": true,
  "reload_style_on_change": true,
  "layer": "top",
  "height": 23,
  "spacing": 3,
  "margin-top": 0,
  "margin-right": 0,
  "margin-left": 0,
  "modules-left": [
    "group/left1"
  ],
  "group/left1": {
    "orientation": "inherit",
    "modules": [
      "hyprland/workspaces",
      "idle_inhibitor",
      "custom/updatespacman",
      "custom/update"
    ]
  },
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "group/right1"
  ],
  "group/right1": {
    "orientation": "inherit",
    "modules": [
      "network",
      "bluetooth",
      "pulseaudio#output",
      "pulseaudio#input",
      "memory",
      "cpu",
      "battery"
    ]
  },
  "hyprland/workspaces": {
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4
      ]
    },
    "on-click": "activate",
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "´üÖ",
    "window-rewrite": {
      "class<.*imv*.>": "´ôÑ",
      "class<.*bambustudio*.>": "¾░É½",
      "class<.*bitwarden*.>": "¯┤Ñ",
